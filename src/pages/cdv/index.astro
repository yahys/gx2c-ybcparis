    // === VCARD DATA ===
    const vcard = [
        'BEGIN:VCARD',
        'VERSION:3.0',
        'N:Benabdelkrim;Yahya;;;',
        'FN:Yahya Benabdelkrim',
        'ORG:GX2C - YBC Paris',
        'TITLE:Fondateur',
        'TEL;TYPE=CELL:+33699233220',
        'EMAIL:yahya.benabdelkrim@ybcparis.com',
        'URL:https://ybcparis.com',
        'ADR;TYPE=WORK:;;99 avenue Achille Peretti;Neuilly-sur-Seine;;92200;France',
        'END:VCARD'
    ].join('\n');

    // === QR CODE ===
    function generateQR() {
        const canvas = document.getElementById('qrCanvas');
        let qr;
        for (let typeNum = 6; typeNum <= 20; typeNum++) {
            try {
                qr = new QRCode(typeNum, 1);
                qr.addData(vcard);
                qr.make();
                break;
            } catch(e) { continue; }
        }
        if (!qr) return;

        const count = qr.getModuleCount();
        const size = 280;
        canvas.width = size;
        canvas.height = size;
        const ctx = canvas.getContext('2d');
        const cellSize = size / count;

        ctx.fillStyle = '#FFFFFF';
        ctx.fillRect(0, 0, size, size);

        ctx.fillStyle = '#1A1917';
        for (let row = 0; row < count; row++) {
            for (let col = 0; col < count; col++) {
                if (qr.isDark(row, col)) {
                    ctx.fillRect(col * cellSize, row * cellSize, Math.ceil(cellSize), Math.ceil(cellSize));
                }
            }
        }
    }
    generateQR();

    // === SAVE CONTACT (vCard download) ===
    function downloadVCard() {
        const blob = new Blob([vcard], { type: 'text/vcard;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'Yahya_Benabdelkrim_GX2C.vcf';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        showToast('Contact téléchargé');
    }

    document.getElementById('saveContact').addEventListener('click', downloadVCard);

    // === SHARE ===
    document.getElementById('shareBtn').addEventListener('click', async function() {
        if (navigator.share) {
            try {
                await navigator.share({
                    title: 'Yahya Benabdelkrim — GX2C',
                    text: 'Carte de visite de Yahya Benabdelkrim, Fondateur GX2C',
                    url: window.location.href
                });
            } catch(e) {}
        } else {
            try {
                await navigator.clipboard.writeText(window.location.href);
                showToast('Lien copié');
            } catch(e) {
                showToast('Impossible de copier le lien');
            }
        }
    });

    // === WALLET MODALS ===
    function openModal(id) {
        const modal = document.getElementById(id);
        modal.classList.add('open');
        // Force reflow then animate
        requestAnimationFrame(() => modal.style.opacity = '1');
    }

    function closeModal(id) {
        const modal = document.getElementById(id);
        modal.classList.remove('open');
    }

    // Apple Wallet
    document.getElementById('appleWalletBtn').addEventListener('click', () => openModal('appleModal'));
    document.getElementById('appleModalClose').addEventListener('click', () => closeModal('appleModal'));
    document.getElementById('appleModalSave').addEventListener('click', () => {
        downloadVCard();
        closeModal('appleModal');
    });

    // Google Wallet
    document.getElementById('googleWalletBtn').addEventListener('click', () => openModal('googleModal'));
    document.getElementById('googleModalClose').addEventListener('click', () => closeModal('googleModal'));
    document.getElementById('googleModalSave').addEventListener('click', () => {
        downloadVCard();
        closeModal('googleModal');
    });

    // Close modal on overlay click
    document.querySelectorAll('.modal-overlay').forEach(overlay => {
        overlay.addEventListener('click', (e) => {
            if (e.target === overlay) overlay.classList.remove('open');
        });
    });

    // === TOAST ===
    function showToast(msg) {
        const toast = document.getElementById('toast');
        toast.textContent = msg;
        toast.classList.add('visible');
        setTimeout(() => toast.classList.remove('visible'), 2500);
    }
    </script>

</body>
</html>
