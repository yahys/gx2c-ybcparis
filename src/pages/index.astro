---
import Base from '../layouts/Base.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Qu'est-ce que GX2C ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GX2C (YB Consulting) est un cabinet de conseil stratégique basé à Paris, spécialisé dans les marchés de capitaux, la trésorerie et l'intelligence artificielle. Nous accompagnons les institutions financières et grands comptes dans leurs transformations les plus critiques."
      }
    },
    {
      "@type": "Question",
      "name": "Quels services propose GX2C ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GX2C opère sur deux verticales : Advisory (Capital Markets, Trésorerie, conformité réglementaire, transformation SI) et AI Products (agents IA, machine learning, data engineering, LLM). Du cadrage stratégique au delivery opérationnel."
      }
    },
    {
      "@type": "Question",
      "name": "Quels clients travaillent avec GX2C ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GX2C accompagne des acteurs majeurs comme SNCF, SNCF Réseau, Société des Grands Projets, Ernst & Young (EY), 3V Finance et Kouver dans leurs projets de transformation et d'innovation IA."
      }
    },
    {
      "@type": "Question",
      "name": "Où est situé GX2C ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GX2C est situé au 99 avenue Achille Peretti, 92200 Neuilly-sur-Seine, France. Contactez-nous à contact@ybcparis.com."
      }
    },
    {
      "@type": "Question",
      "name": "Quelle est l'expertise IA de GX2C ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GX2C conçoit et déploie des produits d'IA propriétaires pour la finance : traitement intelligent de documents (OCR factures), agents IA pour workflows financiers (réconciliation, classification), analytics prédictif (trésorerie, marchés), et modèles LLM sur mesure pour le risque et la conformité."
      }
    }
  ]
};
---

<Base
  title="GX2C — Conseil & Expertise IA | Grands comptes & PME"
  description="GX2C — Cabinet de conseil accompagnant grands comptes et PME. Expertise transverse : IA, Finance, Trésorerie, transformation digitale."
  jsonLd={[faqJsonLd]}
>

<!-- NAVIGATION -->
<nav id="navbar">
    <div class="nav-inner">
        <a href="#" class="logo">GX2C</a>
        <button class="menu-toggle" id="menuToggle" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
        <ul class="nav-links" id="navLinks">
            <li>
                <a href="#expertise">
                    <span data-lang-inline="fr">Nos métiers</span>
                    <span data-lang-inline="en">Our expertise</span>
                </a>
            </li>
            <li>
                <a href="#clients">
                    <span data-lang-inline="fr">Clients</span>
                    <span data-lang-inline="en">Clients</span>
                </a>
            </li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="#contact">Contact</a></li>
            <li>
                <button class="lang-toggle" id="langToggle">EN</button>
            </li>
        </ul>
    </div>
</nav>

<!-- HERO -->
<section class="hero" id="hero">
    <div class="hero-content">
        <div class="hero-tag">
            <span data-lang-inline="fr">Advisory &middot; Technology &middot; Intelligence</span>
            <span data-lang-inline="en">Advisory &middot; Technology &middot; Intelligence</span>
        </div>
        <h1>
            <span data-lang="fr">GX2C — Capital Markets, Treasury &amp; IA :<br>nous transformons la <em>complexité</em> en avantage compétitif</span>
            <span data-lang="en">GX2C — Capital Markets, Treasury &amp; AI:<br>we turn <em>complexity</em> into competitive advantage</span>
        </h1>
        <p class="hero-sub" data-lang="fr">
            Cabinet de conseil stratégique à la croisée de la Finance de Marché, de la Trésorerie et de l'Intelligence Artificielle. Nous concevons les solutions qui redéfinissent la performance.
        </p>
        <p class="hero-sub" data-lang="en">
            Strategic advisory firm at the intersection of Capital Markets, Treasury and Artificial Intelligence. We design the solutions that redefine performance.
        </p>
        <a href="#contact" class="hero-cta">
            <span data-lang-inline="fr">Parlons de votre projet</span>
            <span data-lang-inline="en">Let's discuss your project</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
    </div>
</section>

<!-- EXPERTISE -->
<section class="pillars" id="expertise">
    <div class="section-inner">
        <div class="pillars-header reveal">
            <div class="section-tag">
                <span data-lang-inline="fr">Ce que nous faisons</span>
                <span data-lang-inline="en">What we do</span>
            </div>
            <h2 class="section-title" data-lang="fr">Advisory &amp; IA :<br>deux métiers, une seule exigence</h2>
            <h2 class="section-title" data-lang="en">Advisory &amp; AI:<br>two disciplines, one standard of excellence</h2>
        </div>

        <div class="pillars-stack">
            <div class="pillar reveal">
                <div class="pillar-accent"></div>
                <div class="pillar-content">
                    <h3 class="pillar-title" data-lang="fr">Advisory</h3>
                    <h3 class="pillar-title" data-lang="en">Advisory</h3>
                    <p class="pillar-desc" data-lang="fr">Nous accompagnons les institutions financières et les grands comptes dans leurs programmes de transformation les plus critiques — systèmes d'information, Finance de Marché, Trésorerie, conformité réglementaire. Du cadrage stratégique au delivery opérationnel.</p>
                    <p class="pillar-desc" data-lang="en">We support financial institutions and large corporates through their most critical transformation programs — information systems, Capital Markets, Treasury, regulatory compliance. From strategic scoping to operational delivery.</p>
                    <div class="pillar-tags">
                        <span>Capital Markets</span>
                        <span>Treasury</span>
                        <span>Regulatory</span>
                        <span>SI Transformation</span>
                    </div>
                </div>
            </div>

            <div class="pillar reveal">
                <div class="pillar-accent"></div>
                <div class="pillar-content">
                    <h3 class="pillar-title" data-lang="fr">AI Products</h3>
                    <h3 class="pillar-title" data-lang="en">AI Products</h3>
                    <p class="pillar-desc" data-lang="fr">Nous concevons et déployons des produits d'intelligence artificielle propriétaires qui augmentent la performance de nos clients — automatisation intelligente, analytics prédictif, agents IA. De l'idée au produit en production.</p>
                    <p class="pillar-desc" data-lang="en">We design and deploy proprietary artificial intelligence products that amplify our clients' performance — intelligent automation, predictive analytics, AI agents. From idea to product in production.</p>
                    <div class="pillar-tags">
                        <span>AI Agents</span>
                        <span>Machine Learning</span>
                        <span>Data Engineering</span>
                        <span>LLM</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CLIENTS / TRUST -->
<section class="trust" id="clients">
    <div class="section-inner">
        <div class="trust-header reveal">
            <div class="section-tag">
                <span data-lang-inline="fr">Ils nous font confiance</span>
                <span data-lang-inline="en">They trust us</span>
            </div>
            <h2 class="section-title" data-lang="fr">Des partenaires d'exception</h2>
            <h2 class="section-title" data-lang="en">Exceptional partners</h2>
        </div>

        <div class="marquee-wrapper reveal">
            <div class="marquee">
                <div class="marquee-track">
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/fr/a/a1/Logo_SNCF_%282011%29.svg" alt="SNCF SA - client GX2C" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/fr/e/ec/Logo_SNCF_R%C3%A9seau_2015.svg" alt="SNCF Réseau - client GX2C" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/fr/e/e7/Soci%C3%A9t%C3%A9_des_Grands_Projets_Logo.svg" alt="Société des Grands Projets - client GX2C" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/commons/3/34/EY_logo_2019.svg" alt="Ernst and Young EY - client GX2C" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img logo-dark-bg"><img src="https://www.3vfinance.com/hubfs/3VF_2026_white_Transp.png" alt="3V Finance - client GX2C" loading="lazy" width="150" height="28"></div>
                    <div class="trust-logo-img"><img src="https://www.kouver.fr/wp-content/uploads/2026/01/Kouver-logo-rose.svg#151" alt="Kouver - client GX2C" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-more">
                        <span data-lang-inline="fr">et bien d'autres...</span>
                        <span data-lang-inline="en">and many more...</span>
                    </div>
                    <!-- Duplicate for seamless loop -->
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/fr/a/a1/Logo_SNCF_%282011%29.svg" alt="SNCF SA" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/fr/e/ec/Logo_SNCF_R%C3%A9seau_2015.svg" alt="SNCF Réseau" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/fr/e/e7/Soci%C3%A9t%C3%A9_des_Grands_Projets_Logo.svg" alt="Société des Grands Projets" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/commons/3/34/EY_logo_2019.svg" alt="Ernst and Young" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img logo-dark-bg"><img src="https://www.3vfinance.com/hubfs/3VF_2026_white_Transp.png" alt="3V Finance" loading="lazy" width="150" height="28"></div>
                    <div class="trust-logo-img"><img src="https://www.kouver.fr/wp-content/uploads/2026/01/Kouver-logo-rose.svg#151" alt="Kouver" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-more">
                        <span data-lang-inline="fr">et bien d'autres...</span>
                        <span data-lang-inline="en">and many more...</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="trust-divider"></div>

        <div class="trust-quote reveal">
            <p data-lang="fr">"L'excellence n'est pas un acte, c'est une habitude que nous cultivons à chaque mission."</p>
            <p data-lang="en">"Excellence is not an act, it is a habit we cultivate with every engagement."</p>
        </div>
    </div>
</section>

<!-- FAQ -->
<section class="faq" id="faq" style="background: var(--white); padding: 100px 60px;">
    <div class="section-inner">
        <div class="section-tag">FAQ</div>
        <h2 class="section-title" data-lang="fr">Questions fréquentes</h2>
        <h2 class="section-title" data-lang="en">Frequently asked questions</h2>
        <div style="margin-top: 48px; max-width: 800px;">
            <details style="border-bottom: 1px solid var(--light-gray); padding: 20px 0;">
                <summary style="font-family: var(--serif); font-size: 1.2rem; cursor: pointer; color: var(--text-primary);">Qu'est-ce que GX2C ?</summary>
                <p style="margin-top: 12px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7;">GX2C (YB Consulting) est un cabinet de conseil stratégique basé à Paris, spécialisé dans les marchés de capitaux, la trésorerie et l'intelligence artificielle. Nous accompagnons les institutions financières et grands comptes dans leurs transformations les plus critiques.</p>
            </details>
            <details style="border-bottom: 1px solid var(--light-gray); padding: 20px 0;">
                <summary style="font-family: var(--serif); font-size: 1.2rem; cursor: pointer; color: var(--text-primary);">Quels services propose GX2C ?</summary>
                <p style="margin-top: 12px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7;">Advisory (Capital Markets, Trésorerie, conformité réglementaire, transformation SI) et AI Products (agents IA, machine learning, data engineering, LLM). Du cadrage stratégique au delivery opérationnel.</p>
            </details>
            <details style="border-bottom: 1px solid var(--light-gray); padding: 20px 0;">
                <summary style="font-family: var(--serif); font-size: 1.2rem; cursor: pointer; color: var(--text-primary);">Quels clients travaillent avec GX2C ?</summary>
                <p style="margin-top: 12px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7;">SNCF, SNCF Réseau, Société des Grands Projets, Ernst & Young (EY), 3V Finance et Kouver.</p>
            </details>
            <details style="border-bottom: 1px solid var(--light-gray); padding: 20px 0;">
                <summary style="font-family: var(--serif); font-size: 1.2rem; cursor: pointer; color: var(--text-primary);">Quelle est l'expertise IA de GX2C ?</summary>
                <p style="margin-top: 12px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7;">Traitement intelligent de documents (OCR factures), agents IA pour workflows financiers, analytics prédictif pour la trésorerie, et modèles LLM sur mesure pour le risque et la conformité.</p>
            </details>
            <details style="border-bottom: 1px solid var(--light-gray); padding: 20px 0;">
                <summary style="font-family: var(--serif); font-size: 1.2rem; cursor: pointer; color: var(--text-primary);">Où est situé GX2C ?</summary>
                <p style="margin-top: 12px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7;">99 avenue Achille Peretti, 92200 Neuilly-sur-Seine, France. Contact : contact@ybcparis.com</p>
            </details>
        </div>
    </div>
</section>

<!-- CONTACT -->
<section class="contact" id="contact">
    <div class="section-inner">
        <div class="contact-grid">
            <div class="contact-info reveal">
                <div class="section-tag">Contact</div>
                <h2 class="section-title" data-lang="fr">Construisons ensemble</h2>
                <h2 class="section-title" data-lang="en">Let's build together</h2>
                <p class="section-desc" data-lang="fr">Un projet, une ambition, une question ? Notre équipe est à votre disposition pour en discuter.</p>
                <p class="section-desc" data-lang="en">A project, an ambition, a question? Our team is at your disposal to discuss it.</p>
                <div class="contact-detail">
                    <div class="contact-detail-label">Email</div>
                    <div class="contact-detail-value"><a href="mailto:contact@ybcparis.com">contact@ybcparis.com</a></div>
                </div>
                <div class="contact-detail">
                    <div class="contact-detail-label">
                        <span data-lang-inline="fr">Adresse</span>
                        <span data-lang-inline="en">Address</span>
                    </div>
                    <div class="contact-detail-value">99 avenue Achille Peretti<br>92200 Neuilly-sur-Seine, France</div>
                </div>
            </div>
            <form class="contact-form reveal" id="contactForm" action="https://formspree.io/f/mojnkrqw" method="POST">
                <input type="hidden" name="_replyto" id="hiddenEmail">
                <input type="hidden" name="_subject" value="Nouveau message GX2C">
                <div class="form-row">
                    <div class="form-group">
                        <label for="name"><span data-lang-inline="fr">Nom</span><span data-lang-inline="en">Name</span></label>
                        <input type="text" id="name" name="name" placeholder="John Doe" required>
                    </div>
                    <div class="form-group">
                        <label for="company"><span data-lang-inline="fr">Société</span><span data-lang-inline="en">Company</span></label>
                        <input type="text" id="company" name="company" placeholder="Acme Corp">
                    </div>
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="john@acme.com" required>
                </div>
                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" name="message" rows="4" required></textarea>
                </div>
                <button type="submit" class="form-submit" id="submitBtn">
                    <span data-lang-inline="fr">Envoyer</span>
                    <span data-lang-inline="en">Send</span>
                </button>
                <div id="formStatus" class="form-status"></div>
            </form>
        </div>
    </div>
</section>

<!-- FOOTER -->
<footer>
    <div class="footer-inner">
        <div class="footer-logo">GX2C</div>
        <div class="footer-text">&copy; 2018-2026 GX2C — YB Consulting (EURL). All rights reserved.</div>
    </div>
</footer>

<style>
    /* ===== NAVIGATION ===== */
    #navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: transparent;
        transition: all 0.4s ease;
    }
    #navbar.scrolled {
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--light-gray);
    }
    .nav-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 60px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    #navbar.scrolled .nav-inner { height: 64px; }
    .logo {
        font-family: var(--serif);
        font-size: 1.5rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        color: var(--white);
        text-decoration: none;
        transition: color 0.4s ease;
    }
    #navbar.scrolled .logo { color: var(--text-primary); }
    .nav-links {
        display: flex;
        list-style: none;
        gap: 36px;
        align-items: center;
    }
    .nav-links a {
        font-size: 0.82rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        color: rgba(255,255,255,0.75);
        text-decoration: none;
        transition: color 0.3s ease;
    }
    #navbar.scrolled .nav-links a { color: var(--text-secondary); }
    .nav-links a:hover { color: var(--white); }
    #navbar.scrolled .nav-links a:hover { color: var(--text-primary); }
    .lang-toggle {
        font-family: var(--sans);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        padding: 6px 14px;
        border: 1px solid rgba(255,255,255,0.3);
        background: transparent;
        color: rgba(255,255,255,0.75);
        cursor: pointer;
        transition: all 0.3s ease;
    }
    #navbar.scrolled .lang-toggle {
        border-color: var(--light-gray);
        color: var(--text-secondary);
    }
    .lang-toggle:hover { border-color: var(--accent-gold); color: var(--accent-gold); }
    .menu-toggle {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
    }
    .menu-toggle span {
        width: 22px;
        height: 1.5px;
        background: var(--white);
        transition: all 0.3s ease;
    }
    #navbar.scrolled .menu-toggle span { background: var(--text-primary); }
    .menu-toggle.active span:nth-child(1) { transform: rotate(45deg) translate(4px, 4px); }
    .menu-toggle.active span:nth-child(2) { opacity: 0; }
    .menu-toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(4px, -4px); }

    /* ===== HERO ===== */
    .hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--text-primary);
        padding: 120px 60px 80px;
        position: relative;
        overflow: hidden;
    }
    .hero::before {
        content: '';
        position: absolute;
        top: -30%;
        right: -15%;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(154,140,108,0.08) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }
    .hero-content {
        max-width: 900px;
        position: relative;
        z-index: 1;
    }
    .hero-tag {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--accent-gold);
        margin-bottom: 28px;
        animation: fadeUp 0.8s ease 0.2s both;
    }
    .hero h1 {
        font-family: var(--serif);
        font-size: 3.8rem;
        font-weight: 300;
        line-height: 1.15;
        color: var(--white);
        margin-bottom: 28px;
        animation: fadeUp 0.8s ease 0.4s both;
    }
    .hero h1 em {
        font-style: italic;
        color: var(--accent-gold-light);
    }
    .hero-sub {
        font-size: 1.1rem;
        font-weight: 300;
        line-height: 1.8;
        color: rgba(255,255,255,0.6);
        max-width: 640px;
        margin-bottom: 40px;
        animation: fadeUp 0.8s ease 0.6s both;
    }
    .hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-family: var(--sans);
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-primary);
        background: var(--white);
        padding: 18px 36px;
        text-decoration: none;
        transition: all 0.35s ease;
        animation: fadeUp 0.8s ease 0.8s both;
    }
    .hero-cta svg { width: 18px; height: 18px; }
    .hero-cta:hover {
        background: var(--accent-gold);
        color: var(--white);
        transform: translateY(-2px);
    }

    /* ===== SECTIONS COMMON ===== */
    .section-inner {
        max-width: 1200px;
        margin: 0 auto;
    }
    .section-tag {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent-gold);
        margin-bottom: 16px;
    }
    .section-title {
        font-family: var(--serif);
        font-size: 3rem;
        font-weight: 400;
        color: var(--text-primary);
        line-height: 1.15;
    }
    .section-desc {
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.8;
        color: var(--text-secondary);
        max-width: 560px;
        margin-top: 16px;
    }

    /* ===== EXPERTISE / PILLARS ===== */
    .pillars {
        padding: 120px 60px;
        background: var(--white);
    }
    .pillars-header { margin-bottom: 64px; }
    .pillars-stack {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }
    .pillar {
        display: flex;
        align-items: stretch;
        background: var(--off-white);
        transition: all 0.35s ease;
    }
    .pillar:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.06);
    }
    .pillar-accent {
        width: 4px;
        flex-shrink: 0;
        background: var(--accent-gold);
    }
    .pillar-content {
        padding: 48px 56px;
        flex: 1;
    }
    .pillar-title {
        font-family: var(--serif);
        font-size: 2rem;
        font-weight: 400;
        color: var(--text-primary);
        margin-bottom: 20px;
    }
    .pillar-desc {
        font-size: 0.95rem;
