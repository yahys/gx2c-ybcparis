---
import Base from '../layouts/Base.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Qu'est-ce que GX2C ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GX2C (YB Consulting) est un cabinet de conseil stratégique basé à Paris, spécialisé dans les marchés de capitaux, la trésorerie et l'intelligence artificielle. Nous accompagnons les institutions financières et grands comptes dans leurs transformations les plus critiques."
      }
    },
    {
      "@type": "Question",
      "name": "Quels services propose GX2C ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GX2C opère sur deux verticales : Advisory (Capital Markets, Trésorerie, conformité réglementaire, transformation SI) et AI Products (agents IA, machine learning, data engineering, LLM). Du cadrage stratégique au delivery opérationnel."
      }
    },
    {
      "@type": "Question",
      "name": "Quels clients travaillent avec GX2C ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GX2C accompagne des acteurs majeurs comme SNCF, SNCF Réseau, Société des Grands Projets, Ernst & Young (EY), 3V Finance et Kouver dans leurs projets de transformation et d'innovation IA."
      }
    },
    {
      "@type": "Question",
      "name": "Où est situé GX2C ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GX2C est situé au 99 avenue Achille Peretti, 92200 Neuilly-sur-Seine, France. Contactez-nous à contact@ybcparis.com."
      }
    },
    {
      "@type": "Question",
      "name": "Quelle est l'expertise IA de GX2C ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GX2C conçoit et déploie des solutions d'IA concrètes : agents vocaux intelligents, bases de connaissances connectées, génération de leads automatisée, création de contenus visuels et vidéo, rapprochement comptable intelligent, gestion de patrimoine augmentée, automatisation de processus métier. Du diagnostic au produit en production."
      }
    }
  ]
};
---

<Base
  title="GX2C — Conseil stratégique, Transformation digitale & IA"
  description="GX2C — Cabinet de conseil stratégique accompagnant grands comptes et PME dans leur transformation digitale et leurs projets IA. Expertises : IA, Finance, Trésorerie."
  jsonLd={[faqJsonLd]}
>

<!-- NAVIGATION -->
<nav id="navbar">
    <div class="nav-inner">
        <a href="#" class="logo">GX2C</a>
        <button class="menu-toggle" id="menuToggle" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
        <ul class="nav-links" id="navLinks">
            <li>
                <a href="#expertise">
                    <span data-lang-inline="fr">Nos métiers</span>
                    <span data-lang-inline="en">Our expertise</span>
                </a>
            </li>
            <li>
                <a href="#clients">
                    <span data-lang-inline="fr">Clients</span>
                    <span data-lang-inline="en">Clients</span>
                </a>
            </li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="#contact">Contact</a></li>
            <li>
                <button class="lang-toggle" id="langToggle">EN</button>
            </li>
        </ul>
    </div>
</nav>

<!-- HERO -->
<section class="hero" id="hero">
    <div class="hero-content">
        <div class="hero-tag">
            <span data-lang-inline="fr">Conseil &middot; Transformation &middot; Intelligence Artificielle</span>
            <span data-lang-inline="en">Advisory &middot; Transformation &middot; Artificial Intelligence</span>
        </div>
        <h1>
            <span data-lang="fr">Nous accompagnons votre <em>transformation</em> et construisons vos produits IA</span>
            <span data-lang="en">We drive your <em>transformation</em> and build your AI products</span>
        </h1>
        <p class="hero-sub" data-lang="fr">
            Cabinet de conseil stratégique au service des grands comptes et PME. Transformation digitale, Intelligence Artificielle, Finance &amp; Trésorerie — du cadrage à la mise en production.
        </p>
        <p class="hero-sub" data-lang="en">
            Strategic advisory firm serving large corporates and SMEs. Digital transformation, Artificial Intelligence, Finance &amp; Treasury — from strategy to production.
        </p>
        <a href="#contact" class="hero-cta">
            <span data-lang-inline="fr">Parlons de votre projet</span>
            <span data-lang-inline="en">Let's discuss your project</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
    </div>
</section>

<!-- EXPERTISE -->
<section class="pillars" id="expertise">
    <div class="section-inner">
        <div class="pillars-header reveal">
            <div class="section-tag">
                <span data-lang-inline="fr">Ce que nous faisons</span>
                <span data-lang-inline="en">What we do</span>
            </div>
            <h2 class="section-title" data-lang="fr">Conseil &amp; IA :<br>deux métiers, une seule exigence</h2>
            <h2 class="section-title" data-lang="en">Advisory &amp; AI:<br>two disciplines, one standard of excellence</h2>
        </div>

        <div class="pillars-stack">
            <div class="pillar reveal">
                <div class="pillar-accent"></div>
                <div class="pillar-content">
                    <h3 class="pillar-title" data-lang="fr">Conseil &amp; Transformation</h3>
                    <h3 class="pillar-title" data-lang="en">Advisory &amp; Transformation</h3>
                    <p class="pillar-desc" data-lang="fr">Nous accompagnons grands comptes et PME dans leurs programmes de transformation les plus critiques — stratégie digitale, refonte de systèmes d'information, Finance de Marché, Trésorerie, conformité réglementaire. Du cadrage stratégique au delivery opérationnel.</p>
                    <p class="pillar-desc" data-lang="en">We support large corporates and SMEs through their most critical transformation programs — digital strategy, information systems, Capital Markets, Treasury, regulatory compliance. From strategic scoping to operational delivery.</p>
                    <div class="pillar-tags">
                        <span>Transformation digitale</span>
                        <span>Finance &amp; Trésorerie</span>
                        <span>Conformité</span>
                        <span>Programme management</span>
                    </div>
                </div>
            </div>

            <div class="pillar reveal">
                <div class="pillar-accent"></div>
                <div class="pillar-content">
                    <h3 class="pillar-title" data-lang="fr">IA &amp; Produits</h3>
                    <h3 class="pillar-title" data-lang="en">AI &amp; Products</h3>
                    <p class="pillar-desc" data-lang="fr">Nous concevons et déployons des produits d'intelligence artificielle qui augmentent la performance de nos clients — agents IA, automatisation intelligente, analytics prédictif, LLM sur mesure. De l'idée au produit en production.</p>
                    <p class="pillar-desc" data-lang="en">We design and deploy artificial intelligence products that amplify our clients' performance — AI agents, intelligent automation, predictive analytics, custom LLMs. From idea to product in production.</p>
                    <div class="pillar-tags">
                        <span>Agents IA</span>
                        <span>Machine Learning</span>
                        <span>Data Engineering</span>
                        <span>LLM sur mesure</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- RÉALISATIONS -->
<section class="realisations" id="realisations">
    <div class="section-inner">
        <div class="realisations-header reveal">
            <div class="section-tag">
                <span data-lang-inline="fr">Ce que nous avons construit</span>
                <span data-lang-inline="en">What we've built</span>
            </div>
            <h2 class="section-title" data-lang="fr">Des solutions déployées,<br>des résultats mesurés</h2>
            <h2 class="section-title" data-lang="en">Deployed solutions,<br>measured results</h2>
            <p class="section-desc" data-lang="fr">Chaque projet part d'un problème métier concret. Voici quelques-unes des solutions que nous avons conçues et mises en production.</p>
            <p class="section-desc" data-lang="en">Every project starts from a concrete business problem. Here are some of the solutions we've designed and put into production.</p>
        </div>
        <div class="real-grid reveal">
            <div class="real-card">
                <div class="real-icon">🎙️</div>
                <h3 class="real-title" data-lang="fr">Agent vocal IA</h3>
                <h3 class="real-title" data-lang="en">AI voice agent</h3>
                <p class="real-desc" data-lang="fr">Un assistant téléphonique qui répond 24 h/24, qualifie les appels et prend des rendez-vous. Plus aucun appel manqué.</p>
                <p class="real-desc" data-lang="en">A phone assistant that answers 24/7, qualifies calls and books appointments. No more missed calls.</p>
            </div>
            <div class="real-card">
                <div class="real-icon">📚</div>
                <h3 class="real-title" data-lang="fr">Base de connaissances connectée</h3>
                <h3 class="real-title" data-lang="en">Connected knowledge base</h3>
                <p class="real-desc" data-lang="fr">Un assistant IA branché sur vos documents internes — SharePoint, Confluence, fichiers. Les équipes trouvent l'information en quelques secondes.</p>
                <p class="real-desc" data-lang="en">An AI assistant connected to your internal docs — SharePoint, Confluence, files. Teams find information in seconds.</p>
            </div>
            <div class="real-card">
                <div class="real-icon">📈</div>
                <h3 class="real-title" data-lang="fr">Génération de leads automatisée</h3>
                <h3 class="real-title" data-lang="en">Automated lead generation</h3>
                <p class="real-desc" data-lang="fr">Identification, scoring et prise de contact automatique à grande échelle. Des centaines de prospects qualifiés chaque semaine, sans effort manuel.</p>
                <p class="real-desc" data-lang="en">Identification, scoring and automatic outreach at scale. Hundreds of qualified prospects weekly, with zero manual effort.</p>
            </div>
            <div class="real-card">
                <div class="real-icon">🎬</div>
                <h3 class="real-title" data-lang="fr">Création de vidéos publicitaires</h3>
                <h3 class="real-title" data-lang="en">Advertising video creation</h3>
                <p class="real-desc" data-lang="fr">Génération de visuels et de vidéos promotionnelles personnalisées à la volée. 100 variantes en une journée là où un studio en produit 3.</p>
                <p class="real-desc" data-lang="en">On-the-fly generation of personalized visuals and promotional videos. 100 variants in a day where a studio produces 3.</p>
            </div>
            <div class="real-card">
                <div class="real-icon">💰</div>
                <h3 class="real-title" data-lang="fr">Rapprochement comptable intelligent</h3>
                <h3 class="real-title" data-lang="en">Intelligent bank reconciliation</h3>
                <p class="real-desc" data-lang="fr">Synchronisation bancaire, extraction de justificatifs par IA et rapprochement automatique. Des heures de saisie manuelle éliminées chaque mois.</p>
                <p class="real-desc" data-lang="en">Bank synchronization, AI-powered receipt extraction and automatic matching. Hours of manual entry eliminated monthly.</p>
            </div>
            <div class="real-card">
                <div class="real-icon">🏠</div>
                <h3 class="real-title" data-lang="fr">Gestion de patrimoine augmentée</h3>
                <h3 class="real-title" data-lang="en">Augmented wealth management</h3>
                <p class="real-desc" data-lang="fr">Application de suivi patrimonial avec valorisation en temps réel, simulation fiscale et projection de rendement — le tout centralisé.</p>
                <p class="real-desc" data-lang="en">Wealth tracking application with real-time valuation, tax simulation and yield projection — all centralized.</p>
            </div>
            <div class="real-card">
                <div class="real-icon">🌐</div>
                <h3 class="real-title" data-lang="fr">Sites et supports digitaux</h3>
                <h3 class="real-title" data-lang="en">Websites and digital assets</h3>
                <p class="real-desc" data-lang="fr">Génération de sites web optimisés SEO, blogs automatisés et supports de communication. Du contenu expert produit en continu.</p>
                <p class="real-desc" data-lang="en">SEO-optimized website generation, automated blogs and communication assets. Expert content produced continuously.</p>
            </div>
            <div class="real-card">
                <div class="real-icon">🤖</div>
                <h3 class="real-title" data-lang="fr">Automatisation Q&amp;A métier</h3>
                <h3 class="real-title" data-lang="en">Business Q&amp;A automation</h3>
                <p class="real-desc" data-lang="fr">Des assistants spécialisés qui répondent aux questions récurrentes de vos clients ou de vos équipes — support, RH, juridique, technique.</p>
                <p class="real-desc" data-lang="en">Specialized assistants answering recurring questions from customers or teams — support, HR, legal, technical.</p>
            </div>
            <a href="#contact" class="real-card real-card-cta">
                <div class="real-icon">→</div>
                <h3 class="real-title" data-lang="fr">Et bien d'autres…</h3>
                <h3 class="real-title" data-lang="en">And many more…</h3>
                <p class="real-desc" data-lang="fr">Chaque entreprise a ses propres enjeux. Parlons des vôtres.</p>
                <p class="real-desc" data-lang="en">Every business has its own challenges. Let's talk about yours.</p>
            </a>
        </div>
    </div>
</section>

<!-- CLIENTS / TRUST -->
<section class="trust" id="clients">
    <div class="section-inner">
        <div class="trust-header reveal">
            <div class="section-tag">
                <span data-lang-inline="fr">Ils nous font confiance</span>
                <span data-lang-inline="en">They trust us</span>
            </div>
            <h2 class="section-title" data-lang="fr">Des partenaires d'exception</h2>
            <h2 class="section-title" data-lang="en">Exceptional partners</h2>
        </div>

        <div class="marquee-wrapper reveal">
            <div class="marquee">
                <div class="marquee-track">
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/fr/a/a1/Logo_SNCF_%282011%29.svg" alt="SNCF SA - client GX2C" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/fr/e/ec/Logo_SNCF_R%C3%A9seau_2015.svg" alt="SNCF Réseau - client GX2C" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/fr/e/e7/Soci%C3%A9t%C3%A9_des_Grands_Projets_Logo.svg" alt="Société des Grands Projets - client GX2C" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/commons/3/34/EY_logo_2019.svg" alt="Ernst and Young EY - client GX2C" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img logo-dark-bg"><img src="https://www.3vfinance.com/hubfs/3VF_2026_white_Transp.png" alt="3V Finance - client GX2C" loading="lazy" width="150" height="28"></div>
                    <div class="trust-logo-img"><img src="https://www.kouver.fr/wp-content/uploads/2026/01/Kouver-logo-rose.svg#151" alt="Kouver - client GX2C" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-more">
                        <span data-lang-inline="fr">et bien d'autres...</span>
                        <span data-lang-inline="en">and many more...</span>
                    </div>
                    <!-- Duplicate for seamless loop -->
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/fr/a/a1/Logo_SNCF_%282011%29.svg" alt="SNCF SA" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/fr/e/ec/Logo_SNCF_R%C3%A9seau_2015.svg" alt="SNCF Réseau" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/fr/e/e7/Soci%C3%A9t%C3%A9_des_Grands_Projets_Logo.svg" alt="Société des Grands Projets" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img"><img src="https://upload.wikimedia.org/wikipedia/commons/3/34/EY_logo_2019.svg" alt="Ernst and Young" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-img logo-dark-bg"><img src="https://www.3vfinance.com/hubfs/3VF_2026_white_Transp.png" alt="3V Finance" loading="lazy" width="150" height="28"></div>
                    <div class="trust-logo-img"><img src="https://www.kouver.fr/wp-content/uploads/2026/01/Kouver-logo-rose.svg#151" alt="Kouver" loading="lazy" width="150" height="38"></div>
                    <div class="trust-logo-more">
                        <span data-lang-inline="fr">et bien d'autres...</span>
                        <span data-lang-inline="en">and many more...</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="trust-divider"></div>

        <div class="trust-quote reveal">
            <p data-lang="fr">"L'excellence n'est pas un acte, c'est une habitude que nous cultivons à chaque mission."</p>
            <p data-lang="en">"Excellence is not an act, it is a habit we cultivate with every engagement."</p>
        </div>
    </div>
</section>

<!-- FAQ -->
<section class="faq" id="faq" style="background: var(--white); padding: 100px 60px;">
    <div class="section-inner">
        <div class="section-tag">FAQ</div>
        <h2 class="section-title" data-lang="fr">Questions fréquentes</h2>
        <h2 class="section-title" data-lang="en">Frequently asked questions</h2>
        <div style="margin-top: 48px; max-width: 800px;">
            <details style="border-bottom: 1px solid var(--light-gray); padding: 20px 0;">
                <summary style="font-family: var(--serif); font-size: 1.2rem; cursor: pointer; color: var(--text-primary);">Qu'est-ce que GX2C ?</summary>
                <p style="margin-top: 12px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7;">GX2C (YB Consulting) est un cabinet de conseil stratégique basé à Paris, spécialisé dans les marchés de capitaux, la trésorerie et l'intelligence artificielle. Nous accompagnons les institutions financières et grands comptes dans leurs transformations les plus critiques.</p>
            </details>
            <details style="border-bottom: 1px solid var(--light-gray); padding: 20px 0;">
                <summary style="font-family: var(--serif); font-size: 1.2rem; cursor: pointer; color: var(--text-primary);">Quels services propose GX2C ?</summary>
                <p style="margin-top: 12px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7;">Advisory (Capital Markets, Trésorerie, conformité réglementaire, transformation SI) et AI Products (agents IA, machine learning, data engineering, LLM). Du cadrage stratégique au delivery opérationnel.</p>
            </details>
            <details style="border-bottom: 1px solid var(--light-gray); padding: 20px 0;">
                <summary style="font-family: var(--serif); font-size: 1.2rem; cursor: pointer; color: var(--text-primary);">Quels clients travaillent avec GX2C ?</summary>
                <p style="margin-top: 12px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7;">SNCF, SNCF Réseau, Société des Grands Projets, Ernst & Young (EY), 3V Finance et Kouver.</p>
            </details>
            <details style="border-bottom: 1px solid var(--light-gray); padding: 20px 0;">
                <summary style="font-family: var(--serif); font-size: 1.2rem; cursor: pointer; color: var(--text-primary);">Quelle est l'expertise IA de GX2C ?</summary>
                <p style="margin-top: 12px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7;">Nous concevons et déployons des solutions IA concrètes : agents vocaux intelligents, bases de connaissances connectées aux documents internes, génération de leads automatisée, création de vidéos et visuels publicitaires, rapprochement comptable intelligent, gestion de patrimoine augmentée, sites web et blogs automatisés, automatisation de processus métier. Du diagnostic au produit en production, pour tous les secteurs.</p>
            </details>
            <details style="border-bottom: 1px solid var(--light-gray); padding: 20px 0;">
                <summary style="font-family: var(--serif); font-size: 1.2rem; cursor: pointer; color: var(--text-primary);">Où est situé GX2C ?</summary>
                <p style="margin-top: 12px; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7;">99 avenue Achille Peretti, 92200 Neuilly-sur-Seine, France. Contact : contact@ybcparis.com</p>
            </details>
        </div>
    </div>
</section>

<!-- CONTACT -->
<section class="contact" id="contact">
    <div class="section-inner">
        <div class="contact-grid">
            <div class="contact-info reveal">
                <div class="section-tag">Contact</div>
                <h2 class="section-title" data-lang="fr">Construisons ensemble</h2>
                <h2 class="section-title" data-lang="en">Let's build together</h2>
                <p class="section-desc" data-lang="fr">Un projet, une ambition, une question ? Notre équipe est à votre disposition pour en discuter.</p>
                <p class="section-desc" data-lang="en">A project, an ambition, a question? Our team is at your disposal to discuss it.</p>
                <div class="contact-detail">
                    <div class="contact-detail-label">Email</div>
                    <div class="contact-detail-value"><a href="mailto:contact@ybcparis.com">contact@ybcparis.com</a></div>
                </div>
                <div class="contact-detail">
                    <div class="contact-detail-label">
                        <span data-lang-inline="fr">Adresse</span>
                        <span data-lang-inline="en">Address</span>
                    </div>
                    <div class="contact-detail-value">99 avenue Achille Peretti<br>92200 Neuilly-sur-Seine, France</div>
                </div>
            </div>
            <form class="contact-form reveal" id="contactForm" action="https://formspree.io/f/mojnkrqw" method="POST">
                <input type="hidden" name="_replyto" id="hiddenEmail">
                <input type="hidden" name="_subject" value="Nouveau message GX2C">
                <div class="form-row">
                    <div class="form-group">
                        <label for="name"><span data-lang-inline="fr">Nom</span><span data-lang-inline="en">Name</span></label>
                        <input type="text" id="name" name="name" placeholder="John Doe" required>
                    </div>
                    <div class="form-group">
                        <label for="company"><span data-lang-inline="fr">Société</span><span data-lang-inline="en">Company</span></label>
                        <input type="text" id="company" name="company" placeholder="Acme Corp">
                    </div>
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="john@acme.com" required>
                </div>
                <div class="form-group">
                    <label for="message">Message</label>
                    <textarea id="message" name="message" rows="4" required></textarea>
                </div>
                <button type="submit" class="form-submit" id="submitBtn">
                    <span data-lang-inline="fr">Envoyer</span>
                    <span data-lang-inline="en">Send</span>
                </button>
                <div id="formStatus" class="form-status"></div>
            </form>
        </div>
    </div>
</section>

<!-- FOOTER -->
<footer>
    <div class="footer-inner">
        <div class="footer-logo">GX2C</div>
        <div class="footer-text">&copy; 2018-2026 GX2C — YB Consulting (EURL). All rights reserved.</div>
    </div>
</footer>

<style>
    /* ===== NAVIGATION ===== */
    #navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: transparent;
        transition: all 0.4s ease;
    }
    #navbar.scrolled {
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--light-gray);
    }
    .nav-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 60px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    #navbar.scrolled .nav-inner { height: 64px; }
    .logo {
        font-family: var(--serif);
        font-size: 1.5rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        color: var(--white);
        text-decoration: none;
        transition: color 0.4s ease;
    }
