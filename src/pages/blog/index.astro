---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime()
);

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Base
  title="Blog — GX2C | Insights Capital Markets, Treasury & AI"
  description="Articles et analyses sur les marchés de capitaux, la trésorerie et l'intelligence artificielle par GX2C."
>

<nav id="navbar" class="scrolled">
    <div class="nav-inner">
        <a href="/" class="logo">GX2C</a>
        <ul class="nav-links">
            <li><a href="/#expertise">Nos métiers</a></li>
            <li><a href="/#clients">Clients</a></li>
            <li><a href="/blog" class="active">Blog</a></li>
            <li><a href="/#contact">Contact</a></li>
        </ul>
    </div>
</nav>

<section class="blog-hero">
    <div class="section-inner">
        <div class="section-tag">Insights</div>
        <h1 class="section-title">Blog</h1>
        <p class="blog-hero-sub">Analyses, perspectives et retours d'expérience sur les marchés de capitaux, la trésorerie et l'intelligence artificielle.</p>
    </div>
</section>

<section class="blog-listing">
    <div class="section-inner">
        {posts.length === 0 && (
            <p class="no-posts">Aucun article pour le moment. Revenez bientot.</p>
        )}
        <div class="posts-grid">
            {posts.map((post) => (
                <a href={`/blog/${post.id}/`} class="post-card">
                    <div class="post-card-meta">
                        <span class="post-card-category">{post.data.category}</span>
                        <time datetime={post.data.publishedDate}>{formatDate(post.data.publishedDate)}</time>
                    </div>
                    <h2 class="post-card-title">{post.data.title}</h2>
                    <p class="post-card-desc">{post.data.description}</p>
                    <div class="post-card-tags">
                        {post.data.tags.map((tag: string) => (
                            <span class="post-tag">{tag}</span>
                        ))}
                    </div>
                    <span class="post-card-link">Lire l'article &rarr;</span>
                </a>
            ))}
        </div>
    </div>
</section>

<footer>
    <div class="footer-inner">
        <div class="footer-logo">GX2C</div>
        <div class="footer-text">&copy; 2018-2026 GX2C — YB Consulting (EURL). All rights reserved.</div>
    </div>
</footer>

<style>
    /* NAV — reuse site style, always scrolled state */
    #navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--light-gray);
        transition: all 0.4s ease;
    }
    .nav-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 60px;
        height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .logo {
        font-family: var(--serif);
        font-size: 1.5rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        color: var(--text-primary);
        text-decoration: none;
    }
    .nav-links {
        display: flex;
        list-style: none;
        gap: 36px;
        align-items: center;
    }
    .nav-links a {
        font-size: 0.82rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        color: var(--text-secondary);
        text-decoration: none;
        transition: color 0.3s ease;
    }
    .nav-links a:hover, .nav-links a.active {
        color: var(--text-primary);
    }

    /* BLOG HERO */
    .blog-hero {
        padding: 160px 60px 80px;
        background: var(--off-white);
    }
    .section-inner {
        max-width: 1200px;
        margin: 0 auto;
    }
    .section-tag {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent-gold);
        margin-bottom: 16px;
    }
    .section-title {
        font-family: var(--serif);
        font-size: 3rem;
        font-weight: 400;
        color: var(--text-primary);
        line-height: 1.15;
        margin-bottom: 20px;
    }
    .blog-hero-sub {
        font-size: 1.05rem;
        font-weight: 300;
        line-height: 1.7;
        color: var(--text-secondary);
        max-width: 640px;
    }

    /* BLOG LISTING */
    .blog-listing {
        padding: 80px 60px 120px;
        background: var(--white);
    }
    .posts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 32px;
    }
    .post-card {
        display: flex;
        flex-direction: column;
        padding: 36px;
        background: var(--off-white);
        border: 1px solid var(--light-gray);
        text-decoration: none;
        color: var(--text-primary);
        transition: all 0.35s ease;
    }
    .post-card:hover {
        border-color: var(--accent-gold);
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.06);
    }
    .post-card-meta {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 16px;
        font-size: 0.75rem;
        color: var(--text-secondary);
    }
    .post-card-category {
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent-gold);
        font-size: 0.68rem;
    }
    .post-card-title {
        font-family: var(--serif);
        font-size: 1.5rem;
        font-weight: 400;
        line-height: 1.3;
        margin-bottom: 12px;
    }
    .post-card-desc {
        font-size: 0.9rem;
        font-weight: 300;
        line-height: 1.7;
        color: var(--text-secondary);
        margin-bottom: 20px;
        flex: 1;
    }
    .post-card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 20px;
    }
    .post-tag {
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        padding: 4px 12px;
        background: var(--cream);
        color: var(--text-secondary);
        border-radius: 2px;
    }
    .post-card-link {
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        color: var(--accent-gold);
        transition: color 0.3s ease;
    }
    .post-card:hover .post-card-link {
        color: var(--text-primary);
    }
    .no-posts {
        font-size: 1rem;
        color: var(--text-secondary);
        text-align: center;
        padding: 60px 0;
    }

    /* FOOTER */
    footer {
        background: var(--text-primary);
        padding: 40px 60px;
    }
    .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .footer-logo {
        font-family: var(--serif);
        font-size: 1.2rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        color: rgba(255,255,255,0.8);
    }
    .footer-text {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.4);
    }

    @media (max-width: 768px) {
        .blog-hero { padding: 120px 24px 60px; }
        .blog-listing { padding: 60px 24px 80px; }
        .section-title { font-size: 2.2rem; }
        .posts-grid { grid-template-columns: 1fr; }
        .nav-inner { padding: 0 24px; }
        footer { padding: 32px 24px; }
    }
</style>

</Base>
