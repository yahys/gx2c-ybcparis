---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noIndex?: boolean;
  jsonLd?: object | object[];
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/og-default.png',
  ogType = 'website',
  noIndex = false,
  jsonLd,
} = Astro.props;

const siteName = 'GX2C — YBC Paris';
const fullOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;

const defaultJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "GX2C",
    "alternateName": "YBC Paris",
    "url": "https://ybcparis.com",
    "description": "Cabinet de conseil stratégique accompagnant grands comptes et PME dans leur transformation digitale et leurs projets IA, avec une expertise forte en Finance, Trésorerie et Intelligence Artificielle",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "99 avenue Achille Peretti",
      "addressLocality": "Neuilly-sur-Seine",
      "postalCode": "92200",
      "addressCountry": "FR"
    },
    "email": "contact@ybcparis.com",
    "areaServed": ["FR", "EU"],
    "serviceType": ["Strategic Advisory", "Digital Transformation", "AI Products", "AI Agents", "Management Consulting", "Finance & Treasury Consulting"],
    "knowsAbout": ["Digital Transformation", "Artificial Intelligence", "AI Agents", "LLM", "Management Consulting", "Capital Markets", "Treasury", "Regulatory Compliance", "Program Management"],
    "sameAs": [
      "https://www.linkedin.com/company/gx2c"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "GX2C",
    "url": "https://ybcparis.com",
    "logo": "https://ybcparis.com/favicon.svg",
    "foundingDate": "2018",
    "founder": {
      "@type": "Person",
      "name": "Yahya Benabdelkrim"
    }
  }
];

const extraJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const jsonLdArray = [...defaultJsonLd, ...extraJsonLd];
---

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    {noIndex && <meta name="robots" content="noindex, nofollow">}
    <link rel="canonical" href={canonical}>

    <!-- Open Graph -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content={ogType}>
    <meta property="og:url" content={canonical}>
    <meta property="og:image" content={fullOgImage}>
    <meta property="og:site_name" content={siteName}>
    <meta property="og:locale" content="fr_FR">
    <meta property="og:locale:alternate" content="en_GB">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={fullOgImage}>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="48x48">
    <link rel="apple-touch-icon" href="/favicon.svg">

    <!-- JSON-LD -->
    {jsonLdArray.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}

    <!-- Microsoft Clarity -->
    <script type="text/javascript">
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "vsko2dp4v2");
    </script>

    <!-- GA4 direct (no GTM) -->
    <script type="text/javascript">
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        var _c = localStorage.getItem('gx2c_consent');
        if (_c !== 'denied') {
            gtag('js', new Date());
            gtag('config', 'G-J21ETEPFPL', { send_page_view: true });
        }
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-J21ETEPFPL"></script>

    <!-- Google Fonts — preload to avoid render-blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Manrope:wght@200;300;400;500;600;700&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Manrope:wght@200;300;400;500;600;700&display=swap" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Manrope:wght@200;300;400;500;600;700&display=swap"></noscript>

    <style is:global>
        :root {
            --white: #FFFFFF;
            --off-white: #FAFAF8;
            --cream: #F5F3EF;
            --light-gray: #E8E6E1;
            --mid-gray: #B8B5AD;
            --text-secondary: #6B6860;
            --text-primary: #1A1917;
            --accent: #0F0F0E;
            --accent-gold: #9A8C6C;
            --accent-gold-light: #C4B79A;
            --serif: 'Cormorant Garamond', Georgia, serif;
            --sans: 'Manrope', -apple-system, sans-serif;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }

        body {
            font-family: var(--sans);
            color: var(--text-primary);
            background: var(--white);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            overflow-x: hidden;
        }

        /* Lang hidden */
        [data-lang="en"] { display: none; }
        html[lang="en"] [data-lang="en"] { display: block; }
        html[lang="en"] [data-lang="fr"] { display: none; }
        html[lang="en"] [data-lang-inline="en"] { display: inline; }
        html[lang="en"] [data-lang-inline="fr"] { display: none; }
        html[lang="fr"] [data-lang-inline="fr"] { display: inline; }
        html[lang="fr"] [data-lang-inline="en"] { display: none; }

        /* Animations */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }

        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body>
    <slot />

    <!-- Cookie Consent Banner -->
    <div id="consent-banner" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:9999;background:#1A1917;border-top:1px solid #9A8C6C33;padding:16px 24px;font-family:var(--sans);font-size:13px;color:#B8B5AD;">
        <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
            <p style="margin:0;flex:1;min-width:200px;line-height:1.5;">
                Ce site utilise des cookies analytiques pour mesurer l'audience.
                <a href="/mentions-legales" style="color:#9A8C6C;text-decoration:underline;">En savoir plus</a>
            </p>
            <div style="display:flex;gap:8px;flex-shrink:0;">
                <button id="consent-reject" style="padding:8px 16px;border:1px solid #6B6860;background:transparent;color:#B8B5AD;border-radius:6px;cursor:pointer;font-family:var(--sans);font-size:12px;letter-spacing:0.02em;">Refuser</button>
                <button id="consent-accept" style="padding:8px 16px;border:1px solid #9A8C6C;background:#9A8C6C;color:#1A1917;border-radius:6px;cursor:pointer;font-family:var(--sans);font-size:12px;font-weight:600;letter-spacing:0.02em;">Accepter</button>
            </div>
        </div>
    </div>
    <script type="text/javascript">
        (function() {
            var choice = localStorage.getItem('gx2c_consent');
            if (choice) return;
            var banner = document.getElementById('consent-banner');
            if (banner) banner.style.display = 'block';

            document.getElementById('consent-accept')?.addEventListener('click', function() {
                localStorage.setItem('gx2c_consent', 'granted');
                gtag('js', new Date());
                gtag('config', 'G-J21ETEPFPL', { send_page_view: true });
                banner.style.display = 'none';
            });

            document.getElementById('consent-reject')?.addEventListener('click', function() {
                localStorage.setItem('gx2c_consent', 'denied');
                banner.style.display = 'none';
            });
        })();
    </script>
</body>
</html>
